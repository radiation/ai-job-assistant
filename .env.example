DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ai_job_finder
TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ai_job_finder_test
API_HOST=127.0.0.1
API_PORT=8000
ENABLE_DEV_RESET_API=false

# Document ingestion and extraction
EXTRACTION_ENABLED=false
EXTRACTION_PROVIDER=vertex
VERTEX_PROJECT=
VERTEX_REGION=us-central1
VERTEX_GEMINI_MODEL_ID=gemini-2.5-flash
EXTRACTION_PROMPT_VERSION=career_fact_extraction_v1
EXTRACTION_SCHEMA_VERSION=career_fact_extraction_schema_v1
EXTRACTION_TEMPERATURE=0
EXTRACTION_TIMEOUT_SECONDS=30
EXTRACTION_CHUNK_SIZE=12000
EXTRACTION_MAX_CHUNKS=8
EXTRACTION_MAX_EXTRACTED_CHARACTERS=80000
MAX_UPLOAD_SIZE_BYTES=5242880
LOCAL_DOCUMENT_STORAGE_DIR=.local/document-storage

# Greenhouse public Job Board API ingestion
GREENHOUSE_API_BASE_URL=https://boards-api.greenhouse.io/v1
GREENHOUSE_TIMEOUT_SECONDS=10
GREENHOUSE_TRANSIENT_RETRY_COUNT=2
GREENHOUSE_USER_AGENT=ai-job-finder/0.1
GREENHOUSE_CLOSE_ON_EMPTY_RESULT=false
GREENHOUSE_RETAIN_RAW_PAYLOAD=true
# GREENHOUSE_FAKE_FIXTURE_PATH=/tmp/ai-job-finder-fake-greenhouse.json

# Optional live smoke only; never required for automated tests.
AI_JOB_FINDER_RUN_VERTEX_SMOKE=false
AI_JOB_FINDER_RUN_GREENHOUSE_SMOKE=false
AI_JOB_FINDER_GREENHOUSE_SMOKE_BOARD_TOKEN=
AI_JOB_FINDER_GREENHOUSE_SMOKE_COMPANY=
